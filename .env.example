# ── Google ADK + internal Genesis LLM ───────────────────────────────────────────
# This is a Google ADK project. The ADK agents run on the internal Genesis LLM via
# LiteLLM (an OpenAI-compatible endpoint) — NO Google Cloud, NO Gemini, NO Google key.
# Copy this file to .env and fill in your values (loaded automatically; no export/set).

# The LLM brain for the ADK agents (LiteLLM "provider/model" format):
LLM_MODEL="openai/gpt-oss-120b"
LLM_API_KEY=""                       # your internal Genesis API key (Bearer token)
LLM_API_BASE="https://api.ai.us.lmco.com/v1"   # OpenAI-compatible chat-completions base
LLM_SSL_VERIFY="false"               # internal endpoints often use self-signed certs

# Genesis Assistants API base (for specialist sub-agents in Phase 2; external_assistant_tool):
LM_PLATFORM_BASE_URL="https://api.ai.us.lmco.com/v1"
EXT_ASSISTANT_SSL_VERIFY="false"
# Per-assistant IDs for the specialist sub-agents (from your LM platform dashboard):
# CAM_ASSISTANT_ID=""
# PM_ASSISTANT_ID=""
# RISK_ASSISTANT_ID=""
# RCCA_ASSISTANT_ID=""

# Behavior flags:
# GENESIS_MOCK=1     # force the deterministic offline engine (no key/LLM needed) — demos/CI.
#                    # (Also used automatically when LLM_API_KEY is unset.)
# GENESIS_DEBUG=1    # print the agent's final text / raw model output to the terminal.
