# ── Internal Genesis LLM — the ONLY LLM backend this project uses ────────────────
# No Google (or any other) API key is ever required.
# Copy this file to .env and fill in your values. Both the Python backend
# (python-dotenv) and Vite load .env automatically — no `export` / `set` needed.
LLM_API_KEY=""                       # your internal Genesis API key
PM_ASSISTANT_ID=""                   # the Genesis assistant id to drive (program-mgmt)
GENESIS_BASE_URL="https://api.ai.us.lmco.com/v1"

# Force the offline mock client even if a key is present (first run / CI / demos):
# GENESIS_MOCK=1
