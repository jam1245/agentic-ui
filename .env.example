# ── Internal Genesis LLM — the ONLY LLM backend this project uses ────────────────
# No Google (or any other) API key is ever required.
# Copy this file to .env and fill in your values. Both the Python backend
# (python-dotenv) and Vite load .env automatically — no `export` / `set` needed.

# Required for live Genesis API:
LLM_API_KEY=""                       # your internal Genesis API key (Bearer token)
LLM_MODEL="openai/gpt-oss-120b"      # model name (provider/model format, e.g., openai/gpt-oss-120b)
GENESIS_BASE_URL="https://api.ai.us.lmco.com/v1"

# Optional: assistant ID for reference (not used by completions API directly)
PM_ASSISTANT_ID=""

# Force the offline mock client even if a key is present (first run / CI / demos):
# GENESIS_MOCK=1

# Optional behavior flags:
# GENESIS_REPHRASE=1   # let the LLM reword the (already-correct) computed answers.
#                      # Off by default — reasoning models can leak scaffolding; the
#                      # computed answer is shown unless the reworded text passes a strict filter.
# GENESIS_DEBUG=1      # print each raw model response to the terminal (for tuning the API call).
